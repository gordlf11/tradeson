#!/usr/bin/env sh
# Pre-push gate: build both packages before letting anything reach Cloud Build.
#
# Why this exists: between Apr 20 and May 5 (2026) the tradeson-api Cloud Build
# trigger silently failed every push because nobody was running `npm run build`
# locally. Three weeks of API commits never deployed. The frontend pipeline
# was fine — only the API was broken — so symptoms looked like deploy lag,
# not build failure.
#
# Run from any subdirectory; `npm --prefix` makes the paths absolute.
# Skip with `git push --no-verify` ONLY when you genuinely intend to ship a
# known-broken build (e.g. you're rolling back).

set -e

# Resolve repo root regardless of where the hook fired from.
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "▶ pre-push: api/ tsc"
npm --prefix api run build

echo "▶ pre-push: frontend tsc + vite build"
npm run build

echo "✔ pre-push: both packages compile. Pushing."
