# ── Firebase (already configured in src/services/firebase.ts) ─────────────
# Firebase frontend config is hardcoded with the tradeson-491518 project.
# Security is enforced via Firestore rules (firebase/firestore.rules).
# No env vars needed for Firebase on the frontend.

# ── Backend API ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
APP_URL=http://localhost:5173

# ── Stripe ─────────────────────────────────────────────────────────────────
# Frontend (Vite exposes VITE_ prefixed vars to the browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Backend only (never expose these to the browser)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id_here

# ── Stripe Subscription Price IDs (one per role) ───────────────────────────
# Create these in the Stripe Dashboard → Products → Add Product → Add Price
# or via the Stripe CLI: stripe prices create ...
# Set mode=recurring, interval=month for each.
STRIPE_PRICE_HOMEOWNER=price_your_homeowner_price_id
STRIPE_PRICE_REALTOR=price_your_realtor_price_id
STRIPE_PRICE_PM=price_your_property_manager_price_id
STRIPE_PRICE_LICENSED_TRADE=price_your_licensed_trade_price_id
STRIPE_PRICE_UNLICENSED_TRADE=price_your_unlicensed_trade_price_id

# ── Payout Configuration ───────────────────────────────────────────────────
# Platform fee taken from each job payout (0.15 = 15%)
# Adjust without code changes — applies to both platform-payout and direct-charge flows
PLATFORM_FEE_PERCENT=0.15
