# ── Firebase (already configured in src/services/firebase.ts) ─────────────
# Firebase frontend config is hardcoded with the tradeson-491518 project.
# Security is enforced via Firestore rules (firebase/firestore.rules).
# No env vars needed for Firebase on the frontend.

# ── Backend API ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080

# ── PayBright Sandbox ──────────────────────────────────────────────────────
# Sandbox portal: https://sandbox.paybrightgateway.com
# Store credentials as env vars — never hardcode them.
VITE_PAYBRIGHT_SANDBOX_URL=https://sandbox.paybrightgateway.com
VITE_PAYBRIGHT_SANDBOX_USERNAME=your_paybright_username
VITE_PAYBRIGHT_SANDBOX_PASSWORD=your_paybright_password

# ── Stripe ─────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
