rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isParticipant(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }

    // ── users ──────────────────────────────────────────────────────────────
    // Source of truth for user profile is PostgreSQL (via Cloud Run API).
    // This collection holds client-written fields (e.g., FCM token) only.

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── jobs ───────────────────────────────────────────────────────────────

    match /jobs/{jobId} {
      allow get: if isAdmin()
        || (isSignedIn() && resource.data.customerId == request.auth.uid)
        || (isSignedIn() && resource.data.acceptedTradespersonId == request.auth.uid)
        || (isSignedIn() && resource.data.status == 'open');

      // List queries are constrained by the client's where() clauses.
      // Each returned doc is re-checked by the rule above via `resource.data`.
      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid;

      allow update: if isAdmin()
        || (isSignedIn() && resource.data.customerId == request.auth.uid)
        || (isSignedIn() && resource.data.acceptedTradespersonId == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ── quotes ─────────────────────────────────────────────────────────────

    match /quotes/{quoteId} {
      allow get: if isAdmin()
        || (isSignedIn() && resource.data.tradespersonId == request.auth.uid)
        || (isSignedIn() &&
            get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.customerId == request.auth.uid);

      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.tradespersonId == request.auth.uid;

      allow update: if isAdmin()
        || (isSignedIn() && resource.data.tradespersonId == request.auth.uid)
        || (isSignedIn() &&
            get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.customerId == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ── threads (messaging) ────────────────────────────────────────────────
    // Matches src/services/messagingService.ts

    match /threads/{threadId} {
      allow get, list: if isAdmin() || isParticipant(resource.data.participants);

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isAdmin() || isParticipant(resource.data.participants);

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow get, list: if isAdmin()
          || isParticipant(get(/databases/$(database)/documents/threads/$(threadId)).data.participants);

        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && isParticipant(get(/databases/$(database)/documents/threads/$(threadId)).data.participants);

        // Only allow marking as read; no edit/delete by users.
        allow update: if isParticipant(get(/databases/$(database)/documents/threads/$(threadId)).data.participants)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

        allow delete: if isAdmin();
      }
    }

    // ── reviews ────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.reviewerId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ── compliance_submissions ────────────────────────────────────────────

    match /compliance_submissions/{subId} {
      allow get: if isAdmin()
        || (isSignedIn() && resource.data.tradespersonId == request.auth.uid);

      allow list: if isAdmin();

      allow create: if isSignedIn()
        && request.resource.data.tradespersonId == request.auth.uid;

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ── flagged_accounts ──────────────────────────────────────────────────

    match /flagged_accounts/{flagId} {
      allow read, write: if isAdmin();
    }

    // ── audit_log ─────────────────────────────────────────────────────────
    // Writable by any authenticated user (admin actions logged from client
    // via logAdminAction); readable only by admins.

    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── platform_metrics ──────────────────────────────────────────────────

    match /platform_metrics/{metricId} {
      allow read, write: if isAdmin();
    }

    // ── Legacy collections ────────────────────────────────────────────────
    // `messaging_threads` is written by the seed script but the runtime
    // uses `threads`. Locked down until the seed is migrated.

    match /messaging_threads/{threadId} {
      allow read, write: if isAdmin();
      match /{document=**} {
        allow read, write: if isAdmin();
      }
    }

    match /conversations/{convId} {
      allow read, write: if isAdmin();
      match /{document=**} {
        allow read, write: if isAdmin();
      }
    }

    match /tracking/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.tradesperson_id == request.auth.uid;
    }

    // ── Default deny ──────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
