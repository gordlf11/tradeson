rules_version = '2';

// TradesOn Firestore Security Rules
//
// Architecture (see CLAUDE.md "🏗️ Architecture"):
//   Source of truth for users/jobs/quotes/compliance is Postgres, via the
//   Cloud Run API. This ruleset scopes Firestore client access to messaging,
//   FCM token storage, and a few admin-writable audit paths. Everything
//   else is admin-only, both to harden the surface and to keep future
//   Firestore→BigQuery mirrors read-safe.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isParticipant(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }

    // Return the set of fields the request is trying to change.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ── users ──────────────────────────────────────────────────────────────
    // Profile data lives in Postgres. Firestore holds FCM token only —
    // owner may read their doc and update `fcmToken` (for push notifications).

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();

      // Owner may create their own doc but only with fcmToken (and empty
      // or missing is fine). Admin may create anything.
      allow create: if isAdmin()
        || (isOwner(uid) && request.resource.data.keys().hasOnly(['fcmToken']));

      // Owner may update ONLY fcmToken. Everything else must go through the
      // Cloud Run API, which uses the Admin SDK and bypasses rules.
      allow update: if isAdmin()
        || (isOwner(uid) && changedKeys().hasOnly(['fcmToken']));

      allow delete: if isAdmin();
    }

    // ── threads (messaging) ────────────────────────────────────────────────
    // Only path where clients hold live listeners. Schema enforced by
    // src/services/messagingService.ts.

    match /threads/{threadId} {
      allow get, list: if isAdmin() || isParticipant(resource.data.participants);

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isAdmin() || isParticipant(resource.data.participants);

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow get, list: if isAdmin()
          || isParticipant(get(/databases/$(database)/documents/threads/$(threadId)).data.participants);

        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && isParticipant(get(/databases/$(database)/documents/threads/$(threadId)).data.participants);

        // Only the `read` flag can be toggled by participants.
        allow update: if isParticipant(get(/databases/$(database)/documents/threads/$(threadId)).data.participants)
          && changedKeys().hasOnly(['read']);

        allow delete: if isAdmin();
      }
    }

    // ── reviews (client-written today, migrating to Postgres) ──────────────
    // `messagingService.submitReview` still writes here. Once reviews move
    // to the Cloud Run API, tighten this to admin-only write.

    match /reviews/{reviewId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.reviewerId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ── audit_log ─────────────────────────────────────────────────────────
    // Admin actions written from the client via logAdminAction. Reads are
    // admin-only so non-admins can't enumerate audit entries.

    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── PG-backed collections (admin-only on Firestore) ────────────────────
    // Clients reach these entities through the Cloud Run API. Firestore
    // copies exist only as future BigQuery mirror targets; locking them to
    // admin prevents accidental dual-write from future client code.

    match /jobs/{jobId} {
      allow read, write: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read, write: if isAdmin();
    }

    match /compliance_submissions/{subId} {
      allow read, write: if isAdmin();
    }

    match /flagged_accounts/{flagId} {
      allow read, write: if isAdmin();
    }

    match /platform_metrics/{metricId} {
      allow read, write: if isAdmin();
    }

    // ── Legacy / deprecated ──────────────────────────────────────────────
    // Pre-architecture-split collections that nothing currently reads or
    // writes. Kept admin-accessible so an admin can inspect / clean them,
    // closed to everyone else.

    match /messaging_threads/{threadId} {
      allow read, write: if isAdmin();
      match /{document=**} {
        allow read, write: if isAdmin();
      }
    }

    match /conversations/{convId} {
      allow read, write: if isAdmin();
      match /{document=**} {
        allow read, write: if isAdmin();
      }
    }

    // Live tracking — reserved for future tradesperson en-route feature.
    // Any signed-in user can read; only the tradesperson can write their
    // own location.
    match /tracking/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.tradesperson_id == request.auth.uid;
    }

    // ── Default deny ──────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
